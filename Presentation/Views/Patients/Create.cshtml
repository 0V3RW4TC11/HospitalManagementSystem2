@model Patient.PatientCreateViewModel

@{
    ViewData["Title"] = "Create Patient";
}

<h1>Create Patient</h1>
<div class="row">
    <div class="col-md-12">
        <form method="post">
            <partial name="_PatientEditPartial" />
            <div class="form-group">
                <label asp-for="PasswordViewModel.Password"></label>
                <input asp-for="PasswordViewModel.Password" class="form-control" type="password" />
                <span asp-validation-for="PasswordViewModel.Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PasswordViewModel.ConfirmPassword"></label>
                <input asp-for="PasswordViewModel.ConfirmPassword" class="form-control" type="password" />
                <span asp-validation-for="PasswordViewModel.ConfirmPassword" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group">
                <a asp-action="@nameof(PatientsController.Index)" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Create</button>
            </div>
        </form>
    </div>
</div>