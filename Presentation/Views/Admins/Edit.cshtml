@using global::ViewModels.Admin;
@using global::ViewModels.User;
@using Helpers;
@model EditViewModel<AdminDataViewModel>

@{
    ViewData["Title"] = "Edit " + Model.UserName;
}

<h1>Edit @Model.UserName</h1>
<div class="row">
    <div class="col-md-4">
        <form asp-action="@nameof(AdminsController.Edit)" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserName" />
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <partial name="_AdminEditPartial" for="Data" />
            <br />
            <div class="form-group">
                <a href="@ViewData["ReturnUrl"]?.ToString()" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>