@using global::ViewModels.Doctor
@using global::ViewModels.Shared
@model ManageUserViewModel<DoctorSpecsView>

@{
    ViewData["Title"] = "Manage " + Model.Edit.UserName;
}

@section Scripts {
    <script src="~/js/account-lockout.js"></script>
}

@Html.AntiForgeryToken()

<h1>Manage @Model.Edit.UserName</h1>
<br />
<partial name="_DoctorPartial" for="Edit.Data" />
<partial name="_DoctorSpecializationsPartial" for="Edit.Data.SpecializationNames" />
<br />
<div>
    <a asp-action="@nameof(DoctorsController.Index)" class="btn btn-secondary">Back</a>
    <a asp-action="@nameof(DoctorsController.Edit)" asp-route-id="@Model.Edit.Id" asp-route-returnUrl="@Url.Action(nameof(DoctorsController.Manage), new { Model.Edit.Id })" class="btn btn-primary">Edit</a>
    <button class="btn @(Model.IsLockedOut ? "btn-success" : "btn-danger")"
            onclick="toggleAccountLockout('@Model.Edit.Id', @Model.IsLockedOut.ToString().ToLower())">
        @(Model.IsLockedOut ? "Enable" : "Disable")
    </button>
    <form asp-action="@nameof(DoctorsController.Delete)" method="post" style="display: inline-block">
        <input type="hidden" name="id" value="@Model.Edit.Id" />
        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
    </form>
</div>