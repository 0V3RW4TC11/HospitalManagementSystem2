@model Doctor.DoctorAndSpecsViewModel

<div>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.FirstName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.FirstName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.LastName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.LastName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.Gender)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.Gender)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.Address)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.Address)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.Phone)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.Phone)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.Email)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.Email)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.DateOfBirth)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.DateOfBirth)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Specializations)
        </dt>
        <dd class="col-sm-10">
            <ul style="list-style-type: none; padding-left: 0">
                @foreach (var name in Model.Specializations)
                {
                    <li>
                        @name
                    </li>
                }
            </ul>
        </dd>
    </dl>
</div>