@using global::ViewModels.Doctor
@using global::ViewModels.Shared
@model EditUserViewModel<DoctorSpecsEdit>

@{
    ViewData["Title"] = "Edit " + Model.UserName;
}

<h1>Edit @Model.UserName</h1>
<div class="row">
    <div class="col-md-12">
        <form asp-action="@nameof(DoctorsController.Edit)" method="post">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserName" />
            <partial name="_DoctorEditPartial" for="Data" />
            <partial name="_DoctorSpecsEditorPartial" for="Data.SpecializationsJson" />
            <br />
            <div class="form-group">
                <a href="@ViewData["ReturnUrl"]" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>