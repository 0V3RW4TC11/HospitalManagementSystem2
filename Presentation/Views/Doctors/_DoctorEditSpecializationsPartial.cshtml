@model Doctor.DoctorEditSpecViewModel[]

<div class="form-group">
    <h5>Specializations</h5>
    @* <span asp-validation-for="SpecializationIds" class="text-danger"></span> *@
    <ul class="list-group">
        @for (var i = 0; i < Model.Length; i++)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <label asp-for="@Model[i].IsSelected">@Model[i].Name</label>
                <input asp-for="@Model[i].IsSelected" style="transform: scale(1.5);" />
                <input type="hidden" asp-for="@Model[i].Id" />
                <input type="hidden" asp-for="@Model[i].Name" />
            </li>
        }
    </ul>
</div> 

