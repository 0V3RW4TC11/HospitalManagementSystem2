@using Presentation.ViewModels.Doctor
@model DoctorEditProfileViewModel

@{
    ViewData["Title"] = "Edit " + Model.UserName;
}

<h1>Edit @Model.UserName</h1>
<div class="row">
    <div class="col-md-12">
        <form asp-action="@nameof(DoctorsController.EditProfile)" method="post" id="doctorUpdate">
            <input type="hidden" asp-for="UserName" />
            <partial name="_DoctorEditPartial" for="Edit" />
            <br />
            <div class="form-group">
                <a asp-action="@nameof(AdminsController.Profile)" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

<script type="module">
    import { DoctorSpecsEditor } from '/js/doctor/doctor-specs-editor.js';
    new DoctorSpecsEditor(
        '/Specializations/Search?name=',
        'Edit_JsonSpecializations',
        'doctorUpdate',
        'specEditor')
</script>