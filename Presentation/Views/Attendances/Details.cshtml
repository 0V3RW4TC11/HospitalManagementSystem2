@using Presentation.ViewModels.Attendance
@model AttendanceDetailsViewModel
@{
    ViewData["Title"] = "Attendance Details";
}

<h1>@ViewData["Title"]</h1>
<br />
<div>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PatientName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.PatientName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DoctorName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DoctorName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Date)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Date)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Attendance.Diagnosis)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Attendance.Diagnosis)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Attendance.Remarks)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Attendance.Remarks)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Attendance.Therapy)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Attendance.Therapy)
        </dd>
    </dl>
</div>
<hr />
<a href="@Model.ReturnUrl" class="btn btn-secondary">Back</a>