@using X.PagedList.Mvc.Core
@model Attendance.AttendanceResultsViewModel

@{
    ViewData["Title"] = Model.ListName;
}

<h1>@ViewData["Title"]</h1>
<br />
<table class="table">
    <thead>
        <tr>
            <th>@Model.ResultName</th>
            <th>@Html.DisplayNameFor(m => m.PagedResults.First().Date)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var result in Model.PagedResults)
        {
            <tr>
                <td>@Html.DisplayFor(item => result.Name)</td>
                <td>@Html.DisplayFor(item => result.Date)</td>
                <td>
                    <a 
                        asp-action="@nameof(AttendancesController.Details)" 
                        asp-route-id="@result.AttendanceId" 
                        asp-route-returnUrl="@Url.Action(Model.ReturnRoute, Model.RouteValues(Model.PagedResults.PageNumber))" 
                        class="btn btn-outline-primary">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination controls -->
<div>
    @Html.PagedListPager(Model.PagedResults, page => Url.Action(Model.ReturnRoute, Model.RouteValues(page)),
    new PagedListRenderOptions {
        LiElementClasses = new string[] { "page-item" },
        PageClasses = new string[] { "page-link" }})
</div>

<!-- Page information -->
<p>
    Showing @Model.PagedResults.FirstItemOnPage to @Model.PagedResults.LastItemOnPage of @Model.PagedResults.TotalItemCount Results
</p>
